{
  "entities": {
    "User": {
      "title": "User",
      "description": "An admin or shop owner in the system.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "owner"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Shop": {
      "title": "Shop",
      "description": "A business location that receives reviews.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the shop."
        },
        "type": {
          "type": "string",
          "description": "The type of business (e.g., Salon, Clinic, Gym)."
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords associated with the shop for AI review generation."
        },
        "reviewLink": {
          "type": "string",
          "format": "uri",
          "description": "The Google Review link for the shop."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this shop."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the shop was created."
        }
      },
      "required": ["name", "type", "keywords", "reviewLink", "ownerId", "createdAt"]
    },
    "Log": {
      "title": "Log",
      "description": "A record of a user interacting with a shop's QR code.",
      "type": "object",
      "properties": {
        "shopId": {
          "type": "string",
          "description": "The ID of the shop that was scanned."
        },
        "rating": {
          "type": "number",
          "description": "The star rating given by the user (1-5)."
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Categories selected by the user."
        },
        "reviewGenerated": {
          "type": "boolean",
          "description": "Whether an AI review was generated."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the interaction occurred."
        }
      },
      "required": ["shopId", "rating", "categories", "reviewGenerated", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/shops/{shopId}": {
      "schema": { "$ref": "#/entities/Shop" },
      "description": "Stores shop details."
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "Stores interaction logs for analytics."
    }
  }
}
